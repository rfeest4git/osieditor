{
  "name": "osi-editor",
  "version": "0.1.0",
  "private": true,
  "description": "Graphical editor for OSI (Open Semantic Interchange) semantic models",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "smoke": "node scripts/smoke.mjs",
    "docker:build": "docker build -t osi-editor .",
    "docker:run": "docker run --rm -p 8080:8080 osi-editor"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.18.0"
  }
}
